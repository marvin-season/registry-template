{
  "name": "registry",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm run registry:build && next build",
    "build:static": "cross-env-shell EXPORT_STATIC=true \"pnpm run registry:build && next build\"",
    "docker:build": "chmod +x scripts/docker.sh && scripts/docker.sh",
    "start": "next start",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:reload": "pm2 reload ecosystem.config.js",
    "pm2:stop": "pm2 stop next-app",
    "pm2:delete": "pm2 delete next-app",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "registry:build": "shadcn build",
    "docs:build": "fumadocs-mdx",
    "format": "biome format --write",
    "lint": "biome lint --write",
    "lint:unsafe": "biome lint --write --unsafe",
    "check": "biome check"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tiptap/core": "^3.14.0",
    "@tiptap/react": "^3.14.0",
    "@tiptap/starter-kit": "^3.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.3.2",
    "fumadocs-ui": "^16.3.2",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.27",
    "lucide-react": "^0.548.0",
    "next": "^16.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-react": "^8.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shadcn": "^3.6.2",
    "simple-git": "^3.30.0",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "unified": "^11.0.5",
    "unist-util-map": "^4.0.0",
    "unist-util-visit": "^5.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20.19.27",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "cross-env": "^10.1.0",
    "fumadocs-mdx": "^13.0.8",
    "glob": "^11.1.0",
    "jsdom": "^27.3.0",
    "pm2": "^6.0.14",
    "shiki": "^3.20.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "use-immer": "^0.11.0",
    "vitest": "^4.0.16"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.2",
      "@types/react-dom": "19.2.2"
    }
  },
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748"
